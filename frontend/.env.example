# Frontend environment variables (Vite). Copy to `frontend/.env` for local
# overrides, or set as project-level env vars on Cloudflare Pages.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Backend base URL. Two accepted forms:
#   - Origin only:        https://bingery.fly.dev      (client appends /api)
#   - Full base with /api: https://bingery.fly.dev/api (used as-is)
#
# Leave unset for:
#   Local dev   — auto-detects http://localhost:5000/api
#   Same-origin — Flask serves the SPA; uses window.location.origin + /api
#
# Set this when the frontend is hosted on a different origin from the backend
# (e.g. Cloudflare Pages frontend + Fly.io backend).
#VITE_API_URL=https://bingery.fly.dev
