# ── Runtime provider ──────────────────────────────────────────────────────
AI_PROVIDER=ollama            # ollama | anthropic

# Anthropic (cloud) — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local) — required when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# ── Flask / DB ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///bingery.db
JWT_SECRET_KEY=change-me

# ── Dub-tracking sources (Plan 4 Phase B) ─────────────────────────────────
# AnimeSchedule.net's v3 API requires a Bearer token. Register at
# https://animeschedule.net/ and paste the token below. Without it the
# bingery-dub-animeschedule cron will 401; Crunchyroll RSS (Tier 1) and
# user-submitted DubReports (Tier 3) work without any extra config.
ANIMESCHEDULE_API_KEY=

# Frontend dev server only (see frontend/.env.example)
