# ── Runtime provider ──────────────────────────────────────────────────────
AI_PROVIDER=ollama            # ollama | anthropic

# Anthropic (cloud) — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local or tunneled) — required when AI_PROVIDER=ollama
# Either OLLAMA_BASE_URL (new) or OLLAMA_URL (legacy) is accepted.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Cloudflare Access (optional) — when the Ollama tunnel is gated behind
# a CF Access service token, set these two and the provider will inject
# the standard headers on every request. Required for the production
# deploy described in docs/DEPLOYMENT.md.
OLLAMA_CF_ACCESS_CLIENT_ID=
OLLAMA_CF_ACCESS_CLIENT_SECRET=

# Generic-headers escape hatch — JSON object. Overlaid on top of CF
# Access headers above. Useful if Ollama sits behind a different auth
# proxy (e.g. Tailscale Funnel + nginx with a Bearer token).
# Example: {"Authorization":"Bearer xxxxx"}
OLLAMA_EXTRA_HEADERS=

# ── Flask / DB ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///bingery.db
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# Comma-separated list of origins allowed to call /api/*. Default '*' is
# fine for local dev. Production REFUSES TO BOOT with '*' — set this to
# your Cloudflare Pages origin (and any extras) before deploy.
# Example: https://bingery.pages.dev,https://bingery.yourdomain.com
CORS_ORIGINS=

# Set to 'production' on Fly.io. Triggers the safety guards in config.py
# that refuse to boot with dev-default secrets or wide-open CORS.
FLASK_ENV=

# ── Dub-tracking sources (Plan 4 Phase B) ─────────────────────────────────
# AnimeSchedule.net's v3 API requires a Bearer token. Register at
# https://animeschedule.net/ and paste the token below. Without it the
# bingery-dub-animeschedule sync will 401; Crunchyroll RSS (Tier 1) and
# the synthetic 8-week-lag seed (seed_dub_schedule.py) work without it.
ANIMESCHEDULE_API_KEY=

# ── Email verification (sign-up codes) ────────────────────────────────────
# 'console' (default) logs the 6-digit code to the server log — for local
# dev and tests. Production requires 'brevo': create a free account at
# https://www.brevo.com, verify a sender address, and create an API key.
EMAIL_PROVIDER=console
BREVO_API_KEY=
EMAIL_FROM=

# Frontend dev server only — see frontend/.env.example
